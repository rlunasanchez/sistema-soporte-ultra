# ==========================================
# CONFIGURACIÓN DEL SERVIDOR
# ==========================================
NODE_ENV=production
PORT=10000

# ==========================================
# BASE DE DATOS (PostgreSQL)
# ==========================================
# Formato: postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql://usuario:password@host:puerto/nombre_db

# ==========================================
# AUTENTICACIÓN JWT
# ==========================================
# Genera una clave segura con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_clave_secreta_muy_segura_aqui

# ==========================================
# RESEND API (Email)
# ==========================================
# Obtén tu API key en: https://resend.com/api-keys
# Plan gratuito: 3000 emails/mes
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# CONFIGURACIÓN OPCIONAL
# ==========================================
# Descomenta para usar dominio propio en Resend (verificado)
# RESEND_FROM_EMAIL=tu-dominio@tuempresa.com

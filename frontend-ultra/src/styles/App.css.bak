:root {
  --container-max: 1400px;
  --radius: 12px;
  --shadow: 0 6px 22px rgba(0, 0, 0, 0.06);
  --gap: 12px;
  --gap-lg: 16px;
  --bg: #f8f9fa;
  --panel: #ffffff;
  --text: #333;
  --muted: #6c757d;
  --primary: #007bff;
  --success: #28a745;
  --danger: #dc3545;
  --warning: #ffc107;
}

/* General */
body {
  font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
  background-color: var(--bg);
  color: var(--text);
  margin: 0;
  padding: 0;
}

.container {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: clamp(12px, 2vw, 24px);
}

/* =========================
   FILTROS / ACCIONES
========================= */
.top-actions {
  display: flex;
  gap: 10px;
  margin-bottom: 10px;
  flex-wrap: wrap;
  justify-content: center;
}

.filters {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 10px;
  align-items: center;
  justify-content: center;
}

.filters input,
.filters select {
  flex: 1 1 180px;
  min-width: 180px;
  padding: 8px 10px;
  border-radius: 8px;
  border: 1px solid #ccc;
  width: 100%;
  font-size: 13px;
  height: 36px;
  box-sizing: border-box;
}

/* =========================
   FORMULARIO (ÓRDENES)
========================= */
  .orden-form {
  width: min(1200px, 100%);
  margin: 0 auto;
display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--gap) var(--gap-lg);
  align-items: start;
  background: var(--panel);
  padding: 24px;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.orden-form input,
.orden-form select {
  padding: 8px 10px;
  border-radius: 8px;
  border: 1px solid #ccc;
  width: 100%;
  font-size: 13px;
  height: 36px;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.orden-form input:focus,
.orden-form select:focus,
.orden-form textarea:focus {
  border-color: var(--primary);
  outline: none;
  box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.15);
}

textarea[name="falla_informada"],
textarea[name="falla_detectada"],
textarea[name="conclusion"] {
  grid-column: 1 / -1;
  width: 100%;
  min-height: 200px;
  padding: 14px 16px;
  font-size: 14px;
  border-radius: 10px;
  border: 1px solid #ccc;
  resize: vertical;
  line-height: 1.7;
  background-color: #fdfdfd;
  box-sizing: border-box;
}

textarea[name="conclusion"] {
  min-height: 240px;
  background-color: #fafafa;
  border: 1px solid #999;
}

.checkbox-group {
  grid-column: 1 / -1;
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  align-items: center;
  margin-top: 2px;
  background-color: #f8f9fa;
  padding: 12px;
  border-radius: 10px;
}

.checkbox-group label {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
}

.form-buttons {
  grid-column: 1 / -1;
  display: flex;
  gap: 10px;
  margin-top: 8px;
  flex-wrap: wrap;
  justify-content: center;
}

.main-btn {
  background: linear-gradient(135deg, var(--success), #218838);
  color: white;
  border: none;
  padding: 10px 18px;
  border-radius: 10px;
  cursor: pointer;
  font-weight: 700;
  font-size: 14px;
}

.export-btn {
  background: linear-gradient(135deg, var(--primary), #0056b3);
}

.main-btn:hover,
.export-btn:hover {
  opacity: 0.92;
}

/* =========================
   TABLA
========================= */
.table-wrapper {
  overflow-x: auto;
  margin-top: 15px;
  background: var(--panel);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

table {
  width: max-content;
  min-width: 100%;
  border-collapse: collapse;
  background-color: #fff;
  border-radius: var(--radius);
  overflow: hidden;
}

table th,
table td {
  padding: 8px 12px;
  text-align: left;
  border-bottom: 1px solid #ddd;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 220px;
}

table th {
  background-color: var(--primary);
  color: white;
  position: sticky;
  top: 0;
  z-index: 2;
}

table tr:nth-child(even) {
  background-color: #f2f2f2;
}

.table-btn {
  padding: 6px 10px;
  margin-right: 6px;
  border-radius: 8px;
  border: none;
  cursor: pointer;
  font-size: 13px;
}

.edit-btn {
  background-color: var(--warning);
  color: #333;
}

.delete-btn {
  background-color: var(--danger);
  color: white;
}

.table-btn:hover {
  opacity: 0.88;
}

/* =========================
   PAGINACIÓN
========================= */
.pagination {
  margin-top: 15px;
  display: flex;
  gap: 6px;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
}

.pagination button {
  padding: 6px 10px;
  border: none;
  background: #e5e5e5;
  cursor: pointer;
  border-radius: 8px;
}

.pagina-activa {
  background: var(--primary);
  color: white;
  font-weight: 700;
}

/* =========================
   USUARIO / CERRAR SESION
========================= */
.user-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
  flex-wrap: wrap;
  justify-content: center;
}

.user-bar span {
  font-weight: 700;
}

/* =========================
   LOGIN (CARD)
========================= */
.auth-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: clamp(16px, 4vw, 32px);
}

.auth-card {
  width: min(520px, 100%);
  background: var(--panel);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 22px;
}

.auth-card h2 {
  margin: 0 0 14px;
  text-align: center;
}

.auth-form {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.auth-form input {
  padding: 10px 12px;
  border-radius: 10px;
  border: 1px solid #ccc;
  font-size: 14px;
  height: 40px;
  box-sizing: border-box;
}

.auth-form input:focus {
  border-color: var(--primary);
  outline: none;
  box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.15);
}

/* =========================
   RESPONSIVE
========================= */
@media (max-width: 1366px) {
    .orden-form {
  width: min(1200px, 100%);
  margin: 0 auto;
padding: 18px;
  }

  table th,
  table td {
    padding: 7px 10px;
    max-width: 180px;
  }
}

@media (max-width: 1200px) {
    .orden-form {
  width: min(1200px, 100%);
  margin: 0 auto;
grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 768px) {
    .orden-form {
  width: min(1200px, 100%);
  margin: 0 auto;
grid-template-columns: 1fr;
    padding: 14px;
  }

  .filters {
    flex-direction: column;
    align-items: stretch;
  }

  .filters input,
  .filters select {
    min-width: 0;
  }
}


.form-container h2 {
  text-align: center;
}

/* =========================
   ORDENES (CENTRADO)
========================= */
.ordenes-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ordenes-container > * {
  width: 100%;
}

.ordenes-container h2 {
  text-align: center;
}
